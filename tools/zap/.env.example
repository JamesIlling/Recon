# OWASP ZAP MCP Server - local dev configuration
# Copy this file to .env and fill in the values before running docker compose up

# Security mode: none | api-key | jwt
# Use none for local dev on a trusted machine only
# Use api-key for shared/team environments
MCP_SECURITY_MODE=api-key

# API key for the MCP server (required when MCP_SECURITY_MODE=api-key)
# Generate with: openssl rand -hex 32
MCP_API_KEY=84e50d6f0342544e93d67e815353e52a5707f4d3c583d12dabe02ef953d8db86

# API key for ZAP itself
# Generate with: openssl rand -hex 32
ZAP_API_KEY=7e9f466f8d0ad0f275afbff5241bd9c7277f9773b01bae7c0c32887c5427cea2

# Local folder ZAP uses for reports and workspace files
LOCAL_ZAP_WORKPLACE_FOLDER=./zap-workplace
