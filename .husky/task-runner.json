{
  "$schema": "https://alirezanet.github.io/Husky.Net/schema.json",
  "tasks": [
    {
      "name": "gitleaks-secrets-scan",
      "group": "pre-commit",
      "command": "gitleaks",
      "args": ["protect", "--staged", "--redact", "-v"],
      "output": "always"
    },
    {
      "name": "dotnet-format",
      "group": "pre-commit",
      "command": "dotnet",
      "args": ["format", "src/", "--verify-no-changes", "--severity", "warn"],
      "include": ["**/*.cs"]
    },
    {
      "name": "dotnet-build",
      "group": "pre-commit",
      "command": "dotnet",
      "args": ["build", "src/", "--no-incremental", "-warnaserror"],
      "include": ["**/*.cs", "**/*.csproj", "**/*.sln"]
    },
    {
      "name": "dotnet-test",
      "group": "pre-commit",
      "command": "dotnet",
      "args": ["test", "src/", "--no-build"],
      "include": ["**/*.cs"]
    },
    {
      "name": "eslint",
      "group": "pre-commit",
      "pathMode": "absolute",
      "cwd": "src/client",
      "command": "npm",
      "args": ["run", "lint"],
      "include": ["**/*.ts", "**/*.tsx", "**/*.js"]
    },
    {
      "name": "tsc",
      "group": "pre-commit",
      "pathMode": "absolute",
      "cwd": "src/client",
      "command": "npx",
      "args": ["tsc", "--noEmit"],
      "include": ["**/*.ts", "**/*.tsx"]
    },
    {
      "name": "vitest",
      "group": "pre-commit",
      "pathMode": "absolute",
      "cwd": "src/client",
      "command": "npm",
      "args": ["run", "test", "--", "--run"],
      "include": ["**/*.ts", "**/*.tsx"]
    }
  ]
}
